{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/api/auth/{**catch-all}"
        }
      },
      "workspace-route": {
        "ClusterId": "workspace-cluster",
        "Match": {
          "Path": "/api/workspaces/{**catch-all}"
        }
      },
      "board-route": {
        "ClusterId": "board-cluster",
        "Match": {
          "Path": "/api/boards/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "auth-destination": {
            "Address": "http://localhost:5048/"
          }
        }
      },
      "workspace-cluster": {
        "Destinations": {
          "workspace-destination": {
            "Address": "http://localhost:5277/"
          }
        }
      },
      "board-cluster": {
        "Destinations": {
          "board-destination": {
            "Address": "http://localhost:PORT_TBD/"
          }
        }
      }
    }
  }
}